# Nusxalab .env nomi bilan saqlang va qiymatlarni to'ldiring.
# .env hech qachon commit qilinmaydi (ildiz .gitignore: .env*).

# Telegram bot tokeni — @BotFather'dan olinadi.
# Loyihadagi maqsad boti: @yoshlaruchuntanlov_bot
BOT_TOKEN=

# Django
SECRET_KEY=
DEBUG=True

# PostgreSQL (docker-compose bilan ishga tushirilsa)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Eskiz SMS xizmati (core/constants.py ishlatadi)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
