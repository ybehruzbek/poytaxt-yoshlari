# Nusxalab .env nomi bilan saqlang va qiymatlarni to'ldiring.
# .env hech qachon commit qilinmaydi (ildiz .gitignore: .env*).

# Telegram bot tokeni — @BotFather'dan olinadi.
# Loyihadagi maqsad boti: @yoshlaruchuntanlov_bot
BOT_TOKEN=

# Savollar e'lon qilinadigan kanal (masalan: @kanal_username yoki -100... ID)
CHANNEL_USERNAME=

# Django
SECRET_KEY=
DEBUG=True

# PostgreSQL — saytning bazasi bilan bo'lishiladi, lekin alohida sxemada.
# Lokal dev: sayt docker-compose'idagi poytaxt-db (host port 5433).
# Dokploy: saytning db servisi host/port'i kiritiladi.
DB_NAME=poytaxt_yoshlari
DB_USER=poytaxt
DB_PASSWORD=
DB_HOST=host.docker.internal
DB_PORT=5433
# Bot jadvallari saytnikidan ajratilgan sxemada turadi
DB_SCHEMA=zakovat

# Eskiz SMS xizmati (core/constants.py ishlatadi)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
