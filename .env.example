# Nusxa oling: cp .env.example .env — va qiymatlarni to'ldiring.

# PostgreSQL (docker-compose.yml dagi `db` servisi)
# Dev'da host port 5433 (lokal Postgres bilan to'qnashmasin deb).
POSTGRES_PASSWORD=kuchli-tasodifiy-parol
DATABASE_URL=postgresql://poytaxt:kuchli-tasodifiy-parol@localhost:5433/poytaxt_yoshlari

# NextAuth — `openssl rand -base64 32` bilan yarating
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Birinchi admin foydalanuvchi (npm run db:seed:admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kamida-12-belgili-parol
