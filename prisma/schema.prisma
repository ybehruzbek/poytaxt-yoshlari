// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Poytaxt Yoshlari — To'liq Ma'lumotlar Bazasi Sxemasi

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ===== LOYIHALAR (Projects) =====
model Project {
  id        String   @id @default(cuid())
  title     String
  desc      String
  image     String
  progress  Int      @default(0)
  status    String   @default("Yangi") // Yangi, Faol, Yakunlangan
  category  String   // IT va Innovatsiya, Ta'lim, Sport, Ekologiya, Bandlik
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== YANGILIKLAR (News) =====
model News {
  id       String  @id @default(cuid())
  title    String
  excerpt  String?
  content  String? // To'liq kontent (HTML yoki Markdown)
  date     String
  tag      String  // Strategiya, Ta'lim, Sport, Texnologiya, Ekologiya
  tagClass String  @default("tag-blue")
  image    String
  featured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== YO'NALISHLAR (Directions / Activities) =====
model Direction {
  id        String @id @default(cuid())
  slug      String @unique
  icon      String
  iconBg    String
  iconColor String
  title     String
  desc      String
  fullDesc  String
  image     String

  // Bog'liq jadvallar
  stats DirectionStat[]
  goals DirectionGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DirectionStat {
  id          String    @id @default(cuid())
  label       String
  value       String
  directionId String
  direction   Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
}

model DirectionGoal {
  id          String    @id @default(cuid())
  text        String
  directionId String
  direction   Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
}

// ===== RAHBARIYAT (Leaders) =====
model Leader {
  id       String @id @default(cuid())
  name     String
  position String
  image    String
  order    Int    @default(0) // Tartib raqami

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== YOSHLAR YETAKCHILARI (Youth Leaders) =====
model YouthLeader {
  id       String @id @default(cuid())
  name     String
  place    String
  image    String
  category String // Oliygoh, Mahalla, Maktab

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== TUMANLAR (Districts) =====
model District {
  id    String @id @default(cuid())
  name  String @unique
  youth String // "12,500+" kabi matn
  lat   Float
  lng   Float
  image String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== HUJJATLAR (Documents) =====
model Document {
  id        String @id @default(cuid())
  title     String
  type      String // PDF, DOCX, XLSX
  size      String // "2.4 MB"
  date      String
  iconBg    String @default("#FEE2E2")
  iconColor String @default("#EF4444")
  icon      String @default("fa-file-pdf")
  fileUrl   String? // Haqiqiy fayl manzili (keyinchalik)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== GALEREYA (Gallery) =====
model GalleryImage {
  id     String @id @default(cuid())
  src    String
  full   String
  alt    String
  aspect String @default("square") // square, tall, wide

  createdAt DateTime @default(now())
}

// ===== MUROJAATLAR (Appeals) =====
model Appeal {
  id        String  @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  type      String  // Taklif, Murojaat, Shikoyat, Tashabbus, Savol
  district  String?
  message   String
  status    String  @default("Yangi") // Yangi, Ko'rib chiqilmoqda, Javob berildi
  response  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== TARIX (Timeline) =====
model TimelineEvent {
  id    String @id @default(cuid())
  year  String
  text  String
  order Int   @default(0)

  createdAt DateTime @default(now())
}

// ===== STATISTIKA =====
model Stat {
  id     String @id @default(cuid())
  target Int
  suffix String @default("")
  label  String
  order  Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== VILOYAT XARITASI (Map Regions) =====
model MapRegion {
  id     String @id @default(cuid())
  name   String @unique
  head   String
  desc   String
  points String // SVG polygon uchun

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== FOYDALANUVCHILAR (Users) =====
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN, MODERATOR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
